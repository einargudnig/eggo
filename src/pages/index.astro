---
import Layout from '../layouts/Layout.astro';

const primaryServices = [
  {
    title: "Vefþróun",
    description: "Sérsniðnar vefsíður og vefforrit byggð á nútíma tækni. Hröð, skalanleg og hönnuð til að skila árangri.",
  },
  {
    title: "Hugbúnaðarþróun",
    description: "Sérsniðnar hugbúnaðarlausnir sem leysa raunveruleg vandamál. Frá innri verkfærum til lausna fyrir viðskiptavini.",
  },
  {
    title: "Gervigreindarsamþætting",
    description: "Nýttu gervigreind til að sjálfvirknivæða verkferla, bæta vörur og opna nýja möguleika í rekstrinum.",
  },
];

const secondaryServices = [
  {
    title: "Sjálfvirknivæðing",
    description: "Tengum kerfin þín saman og látum þau vinna sem eitt.",
  },
  {
    title: "Tækniráðgjöf",
    description: "Arkitektúr, tæknistakksval og stefnumiðuð ráðgjöf.",
  },
  {
    title: "DevOps og ský",
    description: "Innviðir, leiðslur og ferlar sem stækka með þér.",
  },
];
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-surface/80 backdrop-blur-xl">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="text-xl font-bold tracking-tight">
        eggó<span class="logo-dot text-brand">.</span>
      </a>
      <div class="hidden items-center gap-8 sm:flex">
        <a href="#services" class="nav-link text-sm text-text-secondary">Þjónusta</a>
        <a href="#about" class="nav-link text-sm text-text-secondary">Um okkur</a>
        <a href="#contact" class="nav-link text-sm text-text-secondary">Hafa samband</a>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="theme-toggle relative flex h-9 w-9 items-center justify-center rounded-full border border-border/50 text-text-secondary"
        >
          <svg class="h-4 w-4 block dark-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <svg class="h-4 w-4 hidden light-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>
        <!-- Mobile menu toggle -->
        <button
          id="mobile-menu-toggle"
          type="button"
          aria-label="Open menu"
          class="flex h-9 w-9 items-center justify-center rounded-full border border-border/50 text-text-secondary sm:hidden"
        >
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
          </svg>
        </button>
        <a
          href="#contact"
          class="btn-primary hidden rounded-full bg-brand px-5 py-2 text-sm font-medium text-surface sm:inline-flex"
        >
          Hafa samband
        </a>
      </div>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden border-t border-border/50 bg-surface/95 backdrop-blur-xl sm:hidden">
      <div class="flex flex-col gap-1 px-6 py-4">
        <a href="#services" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-text-secondary">Þjónusta</a>
        <a href="#about" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm text-text-secondary">Um okkur</a>
        <a href="#contact" class="mobile-nav-link rounded-lg px-3 py-2.5 text-sm font-medium text-brand">Hafa samband</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="flex min-h-screen items-center px-6">
    <div class="mx-auto max-w-4xl">
      <p class="hero-reveal mb-5 text-sm font-medium text-brand" style="--delay: 0ms">
        Laus fyrir ný verkefni
      </p>

      <h1 class="hero-reveal mb-8 font-serif text-[clamp(2.5rem,6vw,4.5rem)] leading-[1.1] tracking-tight" style="--delay: 80ms">
        Við smíðum hugbúnað<br />
        <em class="text-brand">sem virkar.</em>
      </h1>

      <p class="hero-reveal mb-10 max-w-xl text-lg leading-relaxed text-text-secondary" style="--delay: 160ms">
        Frá vefsíðum til gervigreindar — við hjálpum fyrirtækjum að skila frábærum hugbúnaði.
        Ekkert bull, ekkert óþarfi — betri ferlar, betri árangur.
      </p>

      <div class="hero-reveal flex flex-col gap-4 sm:flex-row" style="--delay: 240ms">
        <a
          href="#contact"
          class="btn-primary rounded-full text-center bg-brand px-8 py-3.5 text-base font-medium text-surface"
        >
          Hafa samband
        </a>
        <a
          href="#services"
          class="btn-secondary rounded-full text-center border border-border px-8 py-3.5 text-base font-medium text-text-secondary"
        >
          Sjá þjónustu
        </a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-32">
    <div class="mx-auto max-w-5xl">
      <div class="reveal mb-16 max-w-2xl">
        <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Þjónusta</p>
        <h2 class="mb-4 font-serif text-[clamp(2rem,4vw,3.25rem)] leading-[1.15] tracking-tight">
          Allt sem þú þarft<br />til að skila góðum árangri.
        </h2>
        <p class="text-lg leading-relaxed text-text-secondary">
          Við erum lítið teymi sem hreyfist hratt. Hvort sem þú þarft heila vöru byggða
          eða bara aðstoð við ákveðna áskorun — við sjáum um það.
        </p>
      </div>

      <!-- Primary services — larger, more detail -->
      <div class="mb-6 grid gap-1.5 sm:grid-cols-3">
        {primaryServices.map((service, i) => (
          <div class={`service-card reveal stagger-${i + 1} group rounded-2xl border border-border/50 bg-surface-elevated p-8`}>
            <h3 class="mb-3 text-lg font-semibold">{service.title}</h3>
            <p class="text-sm leading-relaxed text-text-secondary">{service.description}</p>
          </div>
        ))}
      </div>

      <!-- Secondary services — compact row -->
      <div class="grid gap-1.5 sm:grid-cols-3">
        {secondaryServices.map((service, i) => (
          <div class={`service-card reveal stagger-${i + 4} group flex items-start gap-3 rounded-xl border border-border/30 px-5 py-4`}>
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-brand/60"></span>
            <div>
              <h3 class="text-sm font-semibold">{service.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-text-secondary">{service.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="px-6 py-32">
    <div class="mx-auto max-w-5xl">
      <div class="grid items-start gap-16 lg:grid-cols-[1fr,1fr]">
        <div class="reveal">
          <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Um okkur</p>
          <h2 class="mb-6 font-serif text-[clamp(2rem,4vw,3.25rem)] leading-[1.15] tracking-tight">
            Þú átt vöruna.<br />Við byggjum hana.
          </h2>
          <div class="space-y-4 text-text-secondary leading-relaxed">
            <p>
              Eggó er hugbúnaðar- og tækniráðgjöf byggð á einni meginreglu:
              tæknin á að leysa vandamál, ekki skapa þau.
            </p>
            <p>
              Við trúum á fullt eignarhald — þú átt kóðann, hönnunina og innviðina.
              Engin læsing við ákveðna framleiðendur, engin óþörf flækja.
              Bara hrein vinna sem þú getur tekið með þér og byggt áfram á.
            </p>
            <p>
              Hvort sem þú þarft heila vöru byggða frá grunni, gervigreindarsamþættingu
              sem raunverulega virkar, eða bara annað par af augum á ferlana —
              við erum hér til að hjálpa.
            </p>
          </div>
        </div>

        <div class="reveal mt-2 space-y-6 lg:mt-14">
          <div class="border-l-2 border-brand/40 pl-5">
            <h3 class="mb-1 font-semibold">Fullt eignarhald</h3>
            <p class="text-sm leading-relaxed text-text-secondary">Þú átt allan kóða og hönnun — ekkert er læst inni.</p>
          </div>
          <div class="border-l-2 border-border pl-5">
            <h3 class="mb-1 font-semibold">Hröð framkvæmd</h3>
            <p class="text-sm leading-relaxed text-text-secondary">Lítið teymi, engin skrifræði — frá hugmynd í raunveruleika á skömmum tíma.</p>
          </div>
          <div class="border-l-2 border-border pl-5">
            <h3 class="mb-1 font-semibold">Nútíma tækni</h3>
            <p class="text-sm leading-relaxed text-text-secondary">Við notum bestu verkfærin og nýjustu tæknina til að skila árangri.</p>
          </div>
          <div class="border-l-2 border-border pl-5">
            <h3 class="mb-1 font-semibold">Opin samskipti</h3>
            <p class="text-sm leading-relaxed text-text-secondary">Gegnsæi í öllu — þú veist alltaf hvar verkefnið stendur.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 py-32">
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Hafa samband</p>
      <h2 class="mb-4 font-serif text-[clamp(2rem,4vw,3.25rem)] leading-[1.15] tracking-tight">
        Við skulum byggja<br />eitthvað frábært saman.
      </h2>
      <p class="mb-12 text-lg text-text-secondary">
        Ertu með verkefni í huga? Við viljum endilega heyra frá þér.
        Sendu okkur línu og við svörum eins fljótt og við getum.
      </p>

      <!-- Form wrapper with success state -->
      <div id="form-wrapper" class="relative mx-auto max-w-md">
        <form id="contact-form" class="space-y-4 text-left" novalidate>
          <div class="field-group">
            <input
              type="text"
              name="name"
              placeholder="Nafnið þitt"
              required
              autocomplete="name"
              class="field-input w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none focus:border-brand/50"
            />
            <p class="field-error mt-1.5 hidden text-xs text-red-400"></p>
          </div>
          <div class="field-group">
            <input
              type="email"
              name="email"
              placeholder="netfangið@þitt.is"
              required
              autocomplete="email"
              class="field-input w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none focus:border-brand/50"
            />
            <p class="field-error mt-1.5 hidden text-xs text-red-400"></p>
          </div>
          <div class="field-group">
            <textarea
              name="message"
              placeholder="Segðu okkur frá verkefninu þínu..."
              rows="4"
              required
              maxlength="2000"
              class="field-input w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none focus:border-brand/50 resize-none"
            ></textarea>
            <p class="field-error mt-1.5 hidden text-xs text-red-400"></p>
          </div>
          <p id="form-status" class="text-sm hidden"></p>
          <button
            type="submit"
            class="btn-primary w-full rounded-xl bg-brand py-3.5 text-sm font-medium text-surface disabled:opacity-60"
          >
            Senda skilaboð
          </button>
        </form>

        <!-- Success state — replaces form after send -->
        <div id="form-success" class="hidden flex flex-col items-center justify-center text-center py-12">
          <svg class="success-check mb-5 h-14 w-14 text-brand" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5" class="success-circle" />
            <path d="M8 12.5l2.5 2.5 5.5-5.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="success-tick" />
          </svg>
          <p class="mb-3 text-2xl font-semibold">Skilaboð send!</p>
          <p class="text-base text-text-secondary">Við svörum þér innan 24 klukkustunda.</p>
          <button id="send-another" class="mt-8 text-sm text-brand underline underline-offset-4 decoration-brand/40 hover:decoration-brand transition-colors">
            Senda önnur skilaboð
          </button>
        </div>
      </div>

      <script>
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const status = document.getElementById('form-status')!;
        const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const formSuccess = document.getElementById('form-success')!;
        const sendAnother = document.getElementById('send-another')!;

        const messages: Record<string, string> = {
          name: 'Vinsamlegast sláðu inn nafnið þitt.',
          email: 'Vinsamlegast sláðu inn gilt netfang.',
          message: 'Vinsamlegast skrifaðu skilaboð.',
        };

        function validateField(input: HTMLInputElement | HTMLTextAreaElement) {
          const group = input.closest('.field-group')!;
          const error = group.querySelector('.field-error') as HTMLElement;
          const isValid = input.validity.valid;

          if (!isValid && input.value.length > 0) {
            error.textContent = messages[input.name] || 'Ógilt gildi.';
            error.classList.remove('hidden');
            input.classList.add('!border-red-400/60');
          } else {
            error.classList.add('hidden');
            input.classList.remove('!border-red-400/60');
          }
          return isValid;
        }

        // Validate on blur
        form.querySelectorAll('.field-input').forEach(input => {
          input.addEventListener('blur', () => validateField(input as HTMLInputElement));
          input.addEventListener('input', () => {
            if (!(input as HTMLInputElement).classList.contains('!border-red-400/60')) return;
            validateField(input as HTMLInputElement);
          });
        });

        function showSuccess() {
          form.style.opacity = '0';
          form.style.transform = 'translateY(-8px)';
          setTimeout(() => {
            form.classList.add('hidden');
            formSuccess.classList.remove('hidden');
            formSuccess.style.opacity = '0';
            formSuccess.style.transform = 'translateY(8px)';
            requestAnimationFrame(() => {
              formSuccess.style.transition = 'opacity 400ms ease, transform 400ms cubic-bezier(0.23, 1, 0.32, 1)';
              formSuccess.style.opacity = '1';
              formSuccess.style.transform = 'translateY(0)';
            });
          }, 300);
        }

        sendAnother.addEventListener('click', () => {
          formSuccess.classList.add('hidden');
          form.classList.remove('hidden');
          form.reset();
          form.style.transition = 'opacity 300ms ease, transform 300ms cubic-bezier(0.23, 1, 0.32, 1)';
          form.style.opacity = '1';
          form.style.transform = 'translateY(0)';
        });

        let submitting = false;
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (submitting) return;

          const inputs = form.querySelectorAll('.field-input') as NodeListOf<HTMLInputElement>;
          let allValid = true;
          inputs.forEach(input => {
            if (!validateField(input)) allValid = false;
          });
          if (!allValid) return;

          submitting = true;
          button.disabled = true;
          button.textContent = 'Sendi...';
          status.classList.add('hidden');

          const data = Object.fromEntries(new FormData(form));
          try {
            const res = await fetch('/api/send', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(data),
            });

            if (res.ok) {
              form.style.transition = 'opacity 300ms ease, transform 300ms cubic-bezier(0.23, 1, 0.32, 1)';
              showSuccess();
            } else {
              const body = await res.json();
              status.textContent = body.error || 'Villa kom upp. Reyndu aftur.';
              status.className = 'text-sm text-red-400';
              button.disabled = false;
              button.textContent = 'Senda skilaboð';
            }
          } catch {
            status.textContent = 'Tenging mistókst. Athugaðu netið og reyndu aftur.';
            status.className = 'text-sm text-red-400';
            button.disabled = false;
            button.textContent = 'Senda skilaboð';
          }

          submitting = false;
        });
      </script>

      <div class="mt-12 flex items-center justify-center gap-8 text-sm text-text-secondary">
        <a href="mailto:eggo@eggo.is" class="nav-link">eggo@eggo.is</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border/50 px-6 py-8">
    <div class="mx-auto flex max-w-6xl items-center justify-between text-sm text-text-muted">
      <span>&copy; {new Date().getFullYear()} Eggó. Allur réttur áskilinn.</span>
      <a href="/" class="nav-link font-medium text-text-secondary">
        eggó<span class="logo-dot text-brand">.</span>
      </a>
    </div>
  </footer>
  <!-- Theme transition overlay -->
  <div id="theme-overlay" class="theme-transition-overlay"></div>
</Layout>

<script>
  function initTheme() {
    const html = document.documentElement;
    const toggle = document.getElementById('theme-toggle')!;
    const overlay = document.getElementById('theme-overlay')!;
    const darkIcon = toggle.querySelector('.dark-icon') as HTMLElement;
    const lightIcon = toggle.querySelector('.light-icon') as HTMLElement;

    // Restore saved theme or default to dark
    const saved = localStorage.getItem('theme');
    if (saved === 'light') {
      html.classList.add('light');
    }
    updateIcons();

    function updateIcons() {
      const isLight = html.classList.contains('light');
      darkIcon.style.display = isLight ? 'none' : 'block';
      lightIcon.style.display = isLight ? 'block' : 'none';
    }

    toggle.addEventListener('click', (e) => {
      const rect = toggle.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;

      const isCurrentlyLight = html.classList.contains('light');
      const nextBg = isCurrentlyLight ? '#0a0a0a' : '#fafaf9';

      // Position the overlay origin at the toggle button
      overlay.style.setProperty('--tx', `${x}px`);
      overlay.style.setProperty('--ty', `${y}px`);
      overlay.style.backgroundColor = nextBg;

      // Remove old animation class and force reflow
      overlay.classList.remove('expanding');
      void overlay.offsetWidth;
      overlay.classList.add('expanding');

      // Switch theme partway through the animation
      requestAnimationFrame(() => {
        setTimeout(() => {
          html.classList.toggle('light');
          localStorage.setItem('theme', html.classList.contains('light') ? 'light' : 'dark');
          updateIcons();
        }, 250);
      });

      // Clean up overlay after animation
      overlay.addEventListener('animationend', () => {
        overlay.classList.remove('expanding');
      }, { once: true });
    });
  }

  // Run on initial load and on Astro page transitions
  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>

<script>
  // Mobile menu
  function initMobileMenu() {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!toggle || !menu) return;

    toggle.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      toggle.setAttribute('aria-label', isOpen ? 'Open menu' : 'Close menu');
    });

    // Close on link click
    menu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => menu.classList.add('hidden'));
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>

<script>
  // Scroll-triggered reveal animations
  function initReveal() {
    const elements = document.querySelectorAll('.reveal');
    if (!elements.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '-40px' }
    );

    elements.forEach((el) => observer.observe(el));
  }

  initReveal();
  document.addEventListener('astro:after-swap', initReveal);
</script>

<script is:inline>
  // Prevent flash: apply saved theme immediately (before paint)
  (function() {
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.add('light');
    }
  })();
</script>
