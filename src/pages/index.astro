---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "Vefþróun",
    description: "Sérsniðnar vefsíður og vefforrit byggð á nútíma tækni. Hröð, skallanleg og hönnuð til að skila árangri.",
    icon: "globe",
  },
  {
    title: "Hugbúnaðarþróun",
    description: "Sérsniðnar hugbúnaðarlausnir sem leysa raunveruleg vandamál. Frá innri verkfærum til viðskiptavinamegin lausna.",
    icon: "code",
  },
  {
    title: "Gervigreindarsamþætting",
    description: "Nýttu gervigreind til að sjálfvirknivæða verkferla, bæta vörur og opna nýja möguleika í rekstrinum.",
    icon: "sparkles",
  },
  {
    title: "Sjálfvirknivæðing",
    description: "Fjarlægðu endurtekin verkefni og straumlínulagaðu reksturinn. Við tengum kerfin þín saman og látum þau vinna sem eitt.",
    icon: "zap",
  },
  {
    title: "Tækniráðgjöf",
    description: "Stefnumiðuð tækniráðgjöf sem hjálpar þér að taka réttar ákvarðanir. Arkitektúr, tæknistaflsval og fleira.",
    icon: "compass",
  },
  {
    title: "DevOps og ský",
    description: "Innviðir sem stækka með þínum rekstri. CI/CD leiðslur, skýjaarkitektúr og sjálfvirk uppsetning.",
    icon: "cloud",
  },
];
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border/50 bg-surface/80 backdrop-blur-xl">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href="/" class="text-xl font-bold tracking-tight">
        eggo<span class="text-brand">.</span>
      </a>
      <div class="hidden items-center gap-8 sm:flex">
        <a href="#services" class="text-sm text-text-secondary transition-colors hover:text-text-primary">Þjónusta</a>
        <a href="#about" class="text-sm text-text-secondary transition-colors hover:text-text-primary">Um okkur</a>
        <a href="#contact" class="text-sm text-text-secondary transition-colors hover:text-text-primary">Hafa samband</a>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle theme"
          class="relative flex h-9 w-9 items-center justify-center rounded-full border border-border/50 text-text-secondary transition-colors hover:text-text-primary hover:border-border"
        >
          <!-- Sun icon (visible in dark mode) -->
          <svg class="h-4 w-4 block dark-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon (visible in light mode) -->
          <svg class="h-4 w-4 hidden light-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>
        <a
          href="#contact"
          class="rounded-full bg-brand px-5 py-2 text-sm font-medium text-surface transition-colors hover:bg-brand-dark"
        >
          Hafa samband
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative flex min-h-screen items-center justify-center overflow-hidden px-6">
    <!-- Gradient orb background -->
    <div class="pointer-events-none absolute top-1/4 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand/5 blur-[120px]"></div>
    <div class="pointer-events-none absolute bottom-1/4 right-1/4 h-[400px] w-[400px] rounded-full bg-brand/3 blur-[100px]"></div>

    <div class="relative z-10 mx-auto max-w-4xl text-center">
      <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border px-4 py-1.5 text-sm text-text-secondary">
        <span class="h-1.5 w-1.5 rounded-full bg-brand animate-pulse"></span>
        Laus fyrir ný verkefni
      </div>

      <h1 class="mb-6 text-5xl leading-tight font-bold tracking-tight sm:text-7xl sm:leading-[1.1]">
        Við smíðum hugbúnað<br />
        <span class="text-brand">sem virkar.</span>
      </h1>

      <p class="mx-auto mb-10 max-w-2xl text-lg text-text-secondary sm:text-xl">
        Frá vefsíðum til gervigreindar — við hjálpum fyrirtækjum að skila frábærum hugbúnaði.
        Ekkert bull, ekkert óþarfi — bara hreinn kóði og raunverulegur árangur.
      </p>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="#contact"
          class="rounded-full bg-brand px-8 py-3.5 text-base font-medium text-surface transition-all hover:bg-brand-dark hover:scale-[1.02] active:scale-[0.98]"
        >
          Byrja verkefni
        </a>
        <a
          href="#services"
          class="rounded-full border border-border px-8 py-3.5 text-base font-medium text-text-secondary transition-all hover:border-text-muted hover:text-text-primary"
        >
          Sjá þjónustu okkar
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2">
      <div class="h-10 w-6 rounded-full border-2 border-text-muted p-1">
        <div class="h-2 w-1.5 mx-auto rounded-full bg-text-muted animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 max-w-2xl">
        <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Þjónusta</p>
        <h2 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
          Allt sem þú þarft<br />til að skila góðum hugbúnaði.
        </h2>
        <p class="text-lg text-text-secondary">
          Við erum lítið teymi sem hreyfist hratt. Hvort sem þú þarft heila vöru byggða
          eða bara aðstoð við ákveðna áskorun — við sjáum um það.
        </p>
      </div>

      <div class="grid gap-1 sm:grid-cols-2 lg:grid-cols-3">
        {services.map((service) => (
          <div class="group rounded-2xl border border-border/50 bg-surface-elevated p-8 transition-all hover:border-brand/30 hover:bg-surface-subtle">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              {service.icon === "globe" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5a17.92 17.92 0 01-8.716-2.247m0 0A9 9 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
              )}
              {service.icon === "code" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                </svg>
              )}
              {service.icon === "sparkles" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
                </svg>
              )}
              {service.icon === "zap" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
                </svg>
              )}
              {service.icon === "compass" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                </svg>
              )}
              {service.icon === "cloud" && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 004.5 4.5H18a3.75 3.75 0 001.332-7.257 3 3 0 00-3.758-3.848 5.25 5.25 0 00-10.233 2.33A4.502 4.502 0 002.25 15z" />
                </svg>
              )}
            </div>
            <h3 class="mb-2 text-lg font-semibold">{service.title}</h3>
            <p class="text-sm leading-relaxed text-text-secondary">{service.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="px-6 py-32">
    <div class="mx-auto max-w-6xl">
      <div class="grid items-center gap-16 lg:grid-cols-2">
        <div>
          <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Um okkur</p>
          <h2 class="mb-6 text-4xl font-bold tracking-tight sm:text-5xl">
            Þú átt vöruna.<br />Við byggjum hana.
          </h2>
          <div class="space-y-4 text-text-secondary">
            <p>
              Eggo er hugbúnaðar- og tækniráðgjöf byggð á einni meginreglu:
              tæknin á að leysa vandamál, ekki skapa þau.
            </p>
            <p>
              Við trúum á fullt eignarhald — þú átt kóðann, hönnunina og innviðina.
              Engin læsing við ákveðna framleiðendur, engin óþörf flækja.
              Bara hrein vinna sem þú getur tekið með þér og byggt áfram á.
            </p>
            <p>
              Hvort sem þú þarft heila vöru byggða frá grunni, gervigreindarsamþættingu
              sem raunverulega virkar, eða bara annað par af augum á arkitektúrinn —
              við erum hér til að hjálpa.
            </p>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-1">
          <div class="rounded-2xl border border-border/50 bg-surface-elevated p-8">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" />
              </svg>
            </div>
            <h3 class="mb-1 font-semibold">Fullt eignarhald</h3>
            <p class="text-sm text-text-secondary">Þú átt allan kóða og hönnun — ekkert er læst inni.</p>
          </div>
          <div class="rounded-2xl border border-border/50 bg-surface-elevated p-8">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
            <h3 class="mb-1 font-semibold">Hröð framkvæmd</h3>
            <p class="text-sm text-text-secondary">Lítið teymi, engin skrifræði — frá hugmynd í raunveruleika á skömmum tíma.</p>
          </div>
          <div class="rounded-2xl border border-border/50 bg-surface-elevated p-8">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
              </svg>
            </div>
            <h3 class="mb-1 font-semibold">Nútíma tækni</h3>
            <p class="text-sm text-text-secondary">Við notum bestu verkfærin og nýjustu tæknina til að skila árangri.</p>
          </div>
          <div class="rounded-2xl border border-border/50 bg-surface-elevated p-8">
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-brand/10 text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" />
              </svg>
            </div>
            <h3 class="mb-1 font-semibold">Opin samskipti</h3>
            <p class="text-sm text-text-secondary">Gegnsæi í öllu — þú veist alltaf hvar verkefnið stendur.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="px-6 py-32">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-3 text-sm font-medium tracking-widest text-brand uppercase">Hafa samband</p>
      <h2 class="mb-4 text-4xl font-bold tracking-tight sm:text-5xl">
        Við skulum byggja<br />eitthvað frábært saman.
      </h2>
      <p class="mb-12 text-lg text-text-secondary">
        Ertu með verkefni í huga? Við viljum endilega heyra frá þér.
        Sendu okkur línu og við svörum innan 24 klukkustunda.
      </p>

      <form id="contact-form" class="mx-auto max-w-md space-y-4 text-left">
        <div>
          <input
            type="text"
            name="name"
            placeholder="Nafnið þitt"
            required
            class="w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none transition-colors focus:border-brand/50"
          />
        </div>
        <div>
          <input
            type="email"
            name="email"
            placeholder="netfangið@þitt.is"
            required
            class="w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none transition-colors focus:border-brand/50"
          />
        </div>
        <div>
          <textarea
            name="message"
            placeholder="Segðu okkur frá verkefninu þínu..."
            rows="4"
            required
            class="w-full rounded-xl border border-border bg-surface-elevated px-5 py-3.5 text-sm text-text-primary placeholder:text-text-muted outline-none transition-colors focus:border-brand/50 resize-none"
          ></textarea>
        </div>
        <p id="form-status" class="text-sm hidden"></p>
        <button
          type="submit"
          class="w-full rounded-xl bg-brand py-3.5 text-sm font-medium text-surface transition-all hover:bg-brand-dark hover:scale-[1.01] active:scale-[0.99]"
        >
          Senda skilaboð
        </button>
      </form>

      <script>
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const status = document.getElementById('form-status')!;
        const button = form.querySelector('button[type="submit"]') as HTMLButtonElement;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          button.disabled = true;
          button.textContent = 'Sendi...';
          status.classList.add('hidden');

          const data = Object.fromEntries(new FormData(form));
          const res = await fetch('/api/send', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (res.ok) {
            status.textContent = 'Skilaboð send! Við svörum þér fljótlega.';
            status.className = 'text-sm text-brand';
            form.reset();
          } else {
            const data = await res.json();
            status.textContent = data.error || 'Villa kom upp. Reyndu aftur.';
            status.className = 'text-sm text-red-400';
          }

          button.disabled = false;
          button.textContent = 'Senda skilaboð';
        });
      </script>

      <div class="mt-12 flex items-center justify-center gap-8 text-sm text-text-secondary">
        <a href="mailto:eggo@eggo.is" class="transition-colors hover:text-text-primary">eggo@eggo.is</a>
        <span class="h-1 w-1 rounded-full bg-text-muted"></span>
        <a href="#" class="transition-colors hover:text-text-primary">LinkedIn</a>
        <span class="h-1 w-1 rounded-full bg-text-muted"></span>
        <a href="#" class="transition-colors hover:text-text-primary">GitHub</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="border-t border-border/50 px-6 py-8">
    <div class="mx-auto flex max-w-6xl items-center justify-between text-sm text-text-muted">
      <span>&copy; {new Date().getFullYear()} Eggo. Allur réttur áskilinn.</span>
      <a href="/" class="font-medium text-text-secondary transition-colors hover:text-text-primary">
        eggo<span class="text-brand">.</span>
      </a>
    </div>
  </footer>
  <!-- Theme transition overlay -->
  <div id="theme-overlay" class="theme-transition-overlay"></div>
</Layout>

<script>
  function initTheme() {
    const html = document.documentElement;
    const toggle = document.getElementById('theme-toggle')!;
    const overlay = document.getElementById('theme-overlay')!;
    const darkIcon = toggle.querySelector('.dark-icon') as HTMLElement;
    const lightIcon = toggle.querySelector('.light-icon') as HTMLElement;

    // Restore saved theme or default to dark
    const saved = localStorage.getItem('theme');
    if (saved === 'light') {
      html.classList.add('light');
    }
    updateIcons();

    function updateIcons() {
      const isLight = html.classList.contains('light');
      darkIcon.style.display = isLight ? 'none' : 'block';
      lightIcon.style.display = isLight ? 'block' : 'none';
    }

    toggle.addEventListener('click', (e) => {
      const rect = toggle.getBoundingClientRect();
      const x = rect.left + rect.width / 2;
      const y = rect.top + rect.height / 2;

      const isCurrentlyLight = html.classList.contains('light');
      const nextBg = isCurrentlyLight ? '#0a0a0a' : '#fafafa';

      // Position the overlay origin at the toggle button
      overlay.style.setProperty('--tx', `${x}px`);
      overlay.style.setProperty('--ty', `${y}px`);
      overlay.style.backgroundColor = nextBg;

      // Remove old animation class and force reflow
      overlay.classList.remove('expanding');
      void overlay.offsetWidth;
      overlay.classList.add('expanding');

      // Switch theme partway through the animation
      requestAnimationFrame(() => {
        setTimeout(() => {
          html.classList.toggle('light');
          localStorage.setItem('theme', html.classList.contains('light') ? 'light' : 'dark');
          updateIcons();
        }, 250);
      });

      // Clean up overlay after animation
      overlay.addEventListener('animationend', () => {
        overlay.classList.remove('expanding');
      }, { once: true });
    });
  }

  // Run on initial load and on Astro page transitions
  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
</script>

<script is:inline>
  // Prevent flash: apply saved theme immediately (before paint)
  (function() {
    if (localStorage.getItem('theme') === 'light') {
      document.documentElement.classList.add('light');
    }
  })();
</script>
